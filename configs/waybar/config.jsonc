{
	"layer": "top",
	"position": "top",
	"height": 43,

	"modules-left": [
		"custom/arch",
		"custom/memory",
		"custom/cpu",
		"custom/temperature",
		"custom/disk",
	],
	"modules-center": ["custom/power-mode", "custom/media", "custom/swaync"],
	"modules-right": [
		"custom/volume",
		"hyprland/language",
		"bluetooth",
		"custom/network",
		"clock",
		"custom/battery",
		"custom/tray-toggle",
	],

	"hyprland/workspaces": {
		"format": "{id}",
		"on-click": "activate",
	},

	"hyprland/window": {
		"max-length": 50,
	},

	"clock": {
		"format": " {:%H:%M}",
		"format-alt": " {:%d.%m.%Y}",
		"tooltip-format": "{:%A, %d %B %Y}",
		"on-click-right": "~/.local/bin/waybar-calendar.py",
	},

	"custom/memory": {
		"exec": "~/.local/bin/waybar-memory.sh",
		"interval": 5,
		"signal": 8,
		"return-type": "json",
		"on-click": "kitty -e btop",
		"on-click-right": "~/.local/bin/waybar-stats-toggle.sh",
	},

	"custom/cpu": {
		"exec": "~/.local/bin/waybar-cpu.sh",
		"interval": 2,
		"signal": 8,
		"return-type": "json",
		"on-click": "kitty -e btop",
		"on-click-right": "~/.local/bin/waybar-stats-toggle.sh",
	},

	"custom/temperature": {
		"exec": "~/.local/bin/waybar-temp.sh",
		"interval": 5,
		"signal": 8,
		"return-type": "json",
		"on-click-right": "~/.local/bin/waybar-stats-toggle.sh",
	},

	"custom/disk": {
		"exec": "~/.local/bin/waybar-disk.sh",
		"interval": 30,
		"signal": 8,
		"return-type": "json",
		"on-click-right": "~/.local/bin/waybar-stats-toggle.sh",
	},

	"custom/power-mode": {
		"exec": "~/.local/bin/waybar-power.sh",
		"interval": 5,
		"signal": 12,
		"return-type": "json",
		"on-click": "~/.local/bin/power-cycle.sh",
		"tooltip": true,
	},

	"custom/battery": {
		"exec": "~/.local/bin/waybar-battery.sh",
		"interval": 1,
		"signal": 10,
		"return-type": "json",
		"on-click": "~/.local/bin/waybar-battery-toggle-percent.sh",
		"on-click-right": "~/.local/bin/waybar-battery-toggle.sh",
		"tooltip": true,
	},

	"custom/network": {
		"exec": "~/.local/bin/waybar-network.sh",
		"interval": 5,
		"return-type": "json",
		"on-click": "kitty -e bash -c 'nmcli device wifi list --rescan yes > /dev/null 2>&1; nmtui'",
	},

	"custom/volume": {
		"exec": "~/.local/bin/waybar-volume.sh",
		"interval": 2,
		"signal": 9,
		"return-type": "json",
		"scroll-step": 5,
		"on-click": "pavucontrol",
		"on-click-right": "~/.local/bin/waybar-volume-toggle.sh",
	},

	"bluetooth": {
		"format": "󰂯",
		"format-connected": "󰂱",
		"format-disabled": "",
		"on-click": "blueman-manager",
		"tooltip-format": "No devices connected",
		"tooltip-format-disabled": "Bluetooth off",
		"tooltip-format-connected": "{device_alias} ({num_connections} connected)",
	},

	"custom/power": {
		"exec": "~/.local/bin/power-status.sh",
		"interval": 5,
		"on-click": "~/.local/bin/power-toggle.sh",
		"tooltip": false,
	},

	"hyprland/language": {
		"format": "{}",
		"format-en": "EN",
		"format-ru": "RU",
	},

	"custom/arch": {
		"format": "",
		"on-click": "~/.local/bin/app-launcher.py",
		"tooltip": false,
	},

	// "mpris": {
	// 	"format": "{player_icon} ⏸ {title} — {artist}",
	// 	"format-paused": "{player_icon} ▶ {title} — {artist}",
	// 	"player-icons": {
	// 		"default": "󰎆",
	// 		"spotify": "",
	// 		"firefox": "󰈹",
	// 		"chromium": "󰊯",
	// 	},
	// 	"status-icons": {
	// 		"paused": "󰏤",
	// 	},
	// 	"max-length": 40,
	// 	"tooltip": true,
	// },

	"custom/media": {
		"exec": "~/.local/bin/waybar-media.sh",
		"interval": 3,
		"signal": 13,
		"return-type": "json",
		"max-length": 55,
		"on-click": "~/.local/bin/waybar-media-click.sh",
		"on-click-right": "~/.local/bin/waybar-media-toggle.sh",
	},

	"custom/swaync": {
		"tooltip": false,
		"format": "{icon}",
		"format-icons": {
			"notification": "󰂚",
			"none": "󰂜",
			"dnd-notification": "󰂛",
			"dnd-none": "󰂛",
		},
		"return-type": "json",
		"exec-if": "which swaync-client",
		"exec": "swaync-client -swb",
		"on-click": "swaync-client -t -sw",
		"on-click-right": "swaync-client -d -sw",
		"escape": true,
	},
	"custom/tray-toggle": {
		"exec": "~/.local/bin/waybar-tray-status.sh",
		"interval": "once",
		"signal": 11,
		"return-type": "json",
		"on-click": "~/.local/bin/waybar-tray-toggle.sh",
		"tooltip": true,
	},
	"custom/power-menu": {
		"format": "󰐥",
		"on-click": "~/.local/bin/power-menu.py",
		"tooltip": false,
	},
}
